datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Cliente {
  id            Int           @id @default(autoincrement())
  nombre        String
  correo        String
  telefono      String?
  empresa       String?
  estado        String        @default("activo")
  createdAt     DateTime      @default(now())
  oportunidades Oportunidad[]
  actividades   Actividad[]
}

model Oportunidad {
  id          Int      @id @default(autoincrement())
  titulo      String
  descripcion String?
  valor       Decimal  @default(0)
  estado      String   @default("prospecto") // prospecto | contactado | negociacion | ganado | perdido
  clienteId   Int
  cliente     Cliente  @relation(fields: [clienteId], references: [id])
  createdAt   DateTime @default(now())
}

model Actividad {
  id        Int      @id @default(autoincrement())
  titulo    String
  tipo      String   // llamada | reunion | seguimiento
  fecha     DateTime
  clienteId Int
  cliente   Cliente  @relation(fields: [clienteId], references: [id])
}
